APP_NAME=Smart Parking Prishtina
ENVIRONMENT=development
PARKING_ID=prishtina_center_01
PARKING_NAME=Parkingu Qendror i Prishtinës
TOTAL_SPOTS=20

MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_KEEPALIVE=60
MQTT_TOPIC_ROOT=parking/prishtina/prishtina_center_01

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=parking.raw-events
KAFKA_TOPIC_PROCESSED=parking.processed-events
KAFKA_TOPIC_AI=parking.ai-input
KAFKA_TOPIC_ALERTS=parking.sensor-alerts

SPARK_APP_NAME=SmartParkingSparkStreaming
SPARK_MASTER_URL=local[*]
SPARK_CHECKPOINT_DIR=data/checkpoints/spark
SPARK_TRIGGER_SECONDS=10
SPARK_KAFKA_PACKAGE=org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.1

CASSANDRA_HOSTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=smart_parking
CASSANDRA_DATACENTER=datacenter1

SIMULATION_STEP_SECONDS=5
HEARTBEAT_SECONDS=30
API_HOST=127.0.0.1
API_PORT=8000

BASE_PRICE_EUR=1.0
PEAK_SURCHARGE_EUR=0.40
MAX_PRICE_EUR=3.0
MIN_PRICE_EUR=0.50
